{
  "manifest_version": 3,
  "name": "MarketPrice - Analise de Precos",
  "version": "1.0.0",
  "description": "Captura e analisa precos do Facebook Marketplace para revendedores de celulares",
  "permissions": ["activeTab", "storage", "alarms"],
  "host_permissions": ["*://www.facebook.com/*", "*://marketpricebr.com/*", "*://www.marketpricebr.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://www.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://marketpricebr.com/*", "*://www.marketpricebr.com/*", "*://localhost/*"],
      "js": ["auth-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MarketPrice"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
